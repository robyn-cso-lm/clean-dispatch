# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cleandispatch"

# Microsoft Graph (email sending + file storage)
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""
MAIL_FROM="noreply@cleandispatch.ca"
# OneDrive account that stores uploaded work photos (defaults to MAIL_FROM).
# The app registration needs Files.ReadWrite.All (application permission).
GRAPH_FILES_USER=""
# Where new-application / booking alerts are sent (defaults to MAIL_FROM).
ADMIN_EMAIL=""

# Checkr background checks (US). Leave blank to disable — status stays manual.
CHECKR_API_KEY=""
CHECKR_PACKAGE="tasker_standard"
CHECKR_WORK_STATE="FL"
CHECKR_WEBHOOK_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Booking rules
BOOKING_DEPOSIT_PERCENT="50"
BOOKING_BUFFER_MINUTES="60"
BOOKING_OPEN_TIME="08:00"
BOOKING_CLOSE_TIME="18:00"

# Quo (SMS)
QUO_API_URL="https://api.quosms.com/v1"
QUO_API_KEY=""
QUO_FROM_NUMBER=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# reCAPTCHA v3 (optional — bypassed in dev if not set)
RECAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
