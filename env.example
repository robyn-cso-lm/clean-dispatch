# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cleandispatch"

# Email — sender identity
MAIL_FROM="hello@camica.ca"
MAIL_FROM_NAME="Camica Clean Dispatch"
# Where new-application / booking alerts are sent (defaults to MAIL_FROM).
ADMIN_EMAIL=""

# Email via SMTP (Google Workspace). Preferred when set. For Gmail/Workspace:
# enable 2-Step Verification on the sending account, then create an App Password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="hello@camica.ca"
SMTP_PASS=""   # 16-char Google App Password

# Microsoft Graph — only used for file storage (cleaner photos -> OneDrive),
# and as an email fallback if SMTP is not configured.
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""
# OneDrive account that stores uploaded work photos (defaults to MAIL_FROM).
# Needs Files.ReadWrite.All (application permission). Leave blank to skip photo storage.
GRAPH_FILES_USER=""

# Checkr background checks (US). Leave blank to disable — status stays manual.
CHECKR_API_KEY=""
CHECKR_PACKAGE="tasker_standard"
CHECKR_WORK_STATE="FL"
CHECKR_WEBHOOK_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Booking rules
BOOKING_DEPOSIT_PERCENT="50"
BOOKING_BUFFER_MINUTES="60"
BOOKING_OPEN_TIME="08:00"
BOOKING_CLOSE_TIME="18:00"

# Quo (SMS)
QUO_API_URL="https://api.quosms.com/v1"
QUO_API_KEY=""
QUO_FROM_NUMBER=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# reCAPTCHA v3 (optional — bypassed in dev if not set)
RECAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
